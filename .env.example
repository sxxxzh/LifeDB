PORT=3333
NODE_ENV=production

# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# 认证配置
AUTH_SECRET_KEY=your-auth-secret
JWT_SECRET=your-jwt-secret
TOKEN_EXPIRY_HOURS=24

# AI 配置 - DeepSeek (LLM + Chat + Embedding)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Embedding 配置
EMBEDDING_PROVIDER=deepseek
EMBEDDING_DIMENSION=1024

# LLM 配置 (RAG 使用)
LLM_PROVIDER=deepseek
RAG_TEMPERATURE=0.7

# Zilliz Cloud 向量数据库
ZILLIZ_ENDPOINT=https://your-cluster.serverless.region.cloud.zilliz.com.cn
ZILLIZ_API_KEY=your-zilliz-api-key
ZILLIZ_COLLECTION_NAME=chaos_life

# 迁移控制
MIGRATION_BATCH_SIZE=20
MIGRATION_RATE_LIMIT_MS=2000
